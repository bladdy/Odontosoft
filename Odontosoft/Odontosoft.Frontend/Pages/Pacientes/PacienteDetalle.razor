@page "/pacientes/{Id:guid}"
@using Odontosoft.Frontend.Helpers

<h3 class="text-2xl font-semibold mb-6">Detalle del Paciente</h3>

@if (Paciente == null)
{
    <div class="text-gray-500">Cargando...</div>
}
else
{

    <div class="grid grid-cols-1 lg:grid-cols-3 lg:gap-6">

        <!-- FOTO Y ESTADO -->
        <div class="bg-white shadow rounded-xl p-6 flex flex-col items-center mb-6 lg:mb-0">

            <img src="/user.jpg"
                 class="w-32 h-32 rounded-full border mb-4" />

            <h4 class="text-lg font-semibold">
                @Paciente.Nombre @Paciente.Apellidos
            </h4>

            <span class="text-gray-500 text-sm">
                Expediente: @Paciente.NumeroExpediente
            </span>

            <span class="mt-3 px-3 py-1 text-xs rounded-full
            @(Paciente.Activo ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">

                @(Paciente.Activo ? "Activo" : "Inactivo")

            </span>

        </div>

        <!-- DATOS PERSONALES -->
        <div class="bg-white shadow rounded-xl p-6 col-span-2">

            <h4 class="text-lg font-semibold mb-4">Información Personal</h4>

            <div class="grid grid-cols-2 gap-4 text-sm">

                <div>
                    <label class="text-gray-500">Nombre</label>
                    <p>@Paciente.Nombre</p>
                </div>

                <div>
                    <label class="text-gray-500">Apellidos</label>
                    <p>@Paciente.Apellidos</p>
                </div>

                <div>
                    <label class="text-gray-500">Fecha Nacimiento</label>
                    <p>@Paciente.FechaNacimiento.ToString("dd/MM/yyyy")</p>
                </div>

                <div>
                    <label class="text-gray-500">Edad</label>
                    <p>@DateHelper.GetAge(Paciente.FechaNacimiento) años</p>
                </div>

                <div>
                    <label class="text-gray-500">Sexo</label>
                    <p>@Paciente.Sexo</p>
                </div>

                <div>
                    <label class="text-gray-500">Estado Civil</label>
                    <p>@Paciente.EstadoCivil</p>
                </div>

                <div>
                    <label class="text-gray-500">CURP</label>
                    <p>@Paciente.CURP</p>
                </div>

                <div>
                    <label class="text-gray-500">RFC</label>
                    <p>@Paciente.RFC</p>
                </div>

                <div>
                    <label class="text-gray-500">Grupo Sanguíneo</label>
                    <p>@Paciente.GrupoSanguineo</p>
                </div>

                <div>
                    <label class="text-gray-500">Ocupación</label>
                    <p>@Paciente.Ocupacion</p>
                </div>

            </div>

        </div>

    </div>

    <!-- CONTACTO -->

    <div class="bg-white shadow rounded-xl p-6 mt-6">

        <h4 class="text-lg font-semibold mb-4">Información de Contacto</h4>

        <div class="grid grid-cols-2 gap-4 text-sm">

            <div>
                <label class="text-gray-500">Teléfono</label>
                <p>@Paciente.Telefono</p>
            </div>

            <div>
                <label class="text-gray-500">Email</label>
                <p>@Paciente.Email</p>
            </div>

            <div>
                <label class="text-gray-500">Teléfono Emergencia</label>
                <p>@Paciente.TelefonoEmergencia</p>
            </div>

            <div>
                <label class="text-gray-500">Contacto Emergencia</label>
                <p>@Paciente.ContactoEmergencia</p>
            </div>

        </div>

    </div>

    <!-- DIRECCIÓN -->

    <div class="bg-white shadow rounded-xl p-6 mt-6">

        <h4 class="text-lg font-semibold mb-4">Dirección</h4>

        <div class="grid grid-cols-2 gap-4 text-sm">

            <div>
                <label class="text-gray-500">Dirección</label>
                <p>@Paciente.Direccion</p>
            </div>

            <div>
                <label class="text-gray-500">Ciudad</label>
                <p>@Paciente.Ciudad</p>
            </div>

            <div>
                <label class="text-gray-500">Estado</label>
                <p>@Paciente.Estado</p>
            </div>

            <div>
                <label class="text-gray-500">Código Postal</label>
                <p>@Paciente.CodigoPostal</p>
            </div>

        </div>

    </div>

    <!-- CLÍNICA Y SUCURSAL -->

    <div class="bg-white shadow rounded-xl p-6 mt-6">

        <h4 class="text-lg font-semibold mb-4">Clínica</h4>

        <div class="grid grid-cols-2 gap-4 text-sm">

            <div>
                <label class="text-gray-500">Clínica</label>
                <p>@Paciente.Sucursal?.Clinica?.Nombre</p>
            </div>

            <div>
                <label class="text-gray-500">Sucursal</label>
                <p>@Paciente.Sucursal?.Nombre</p>
            </div>

            <div>
                <label class="text-gray-500">Teléfono</label>
                <p>@Paciente.Sucursal?.Telefono</p>
            </div>

            <div>
                <label class="text-gray-500">Email</label>
                <p>@Paciente.Sucursal?.Email</p>
            </div>

        </div>

    </div>

}
<!-- TABS -->

<div class="bg-white shadow rounded-xl mt-6">

    <div class="flex border-b text-sm">

        <button @onclick="@(() => activeTab = "citas")" 
            
                class="px-4 py-3 @(activeTab == "citas" ? "border-b-2 border-gray-900 text-gray-900" : "text-gray-500")">
            Citas
        </button>

        <button @onclick="@(() => activeTab = "alergias")"
                class="px-4 py-3 @(activeTab == "alergias" ? "border-b-2 border-gray-900 text-gray-900" : "text-gray-500")">
            Alergias
        </button>
        <button 
                @onclick="@(() => activeTab = "antecedentes")"
                class="px-4 py-3 @(activeTab == "antecedentes" ? "border-b-2 border-gray-900 text-gray-900" : "text-gray-500")">
            Antecedentes
        </button>

    </div>

    <div class="p-6">

        <!-- ===================== -->
        <!-- CITAS -->
        <!-- ===================== -->
        @if (activeTab == "citas")
        {
            <div class="overflow-auto max-h-[300px]">

                <table class="min-w-full text-sm text-left">
                    <thead class="bg-gray-100">
                        <tr>
                            <th class="px-4 py-2">Número</th>
                            <th class="px-4 py-2">Fecha</th>
                            <th class="px-4 py-2">Estado</th>
                            <th class="px-4 py-2">Motivo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cita in Paciente.Citas!)
                        {
                            <tr class="border-b">
                                <td class="px-4 py-2">@cita.NumeroCita</td>
                                <td class="px-4 py-2">@cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-4 py-2">
                                    <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-700">
                                        @cita.EstadoCita
                                    </span>
                                </td>
                                <td class="px-4 py-2">@cita.MotivoConsulta</td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        }

        <!-- ===================== -->
        <!-- ALERGIAS -->
        <!-- ===================== -->
        @if (activeTab == "alergias")
        {
            <div class="grid md:grid-cols-2 gap-4">

                @foreach (var alergia in Paciente!.Alergias!)
                {
                    <div class="border rounded-lg p-4">

                        <div class="flex justify-between items-center mb-2">
                            <strong>@alergia.Nombre</strong>

                            <span class="text-xs px-2 py-1 rounded-full
                                @(alergia.Gravedad == "Alta" ? "bg-red-100 text-red-700" :
                                  alergia.Gravedad == "Media" ? "bg-yellow-100 text-yellow-700" :
                                  "bg-green-100 text-green-700")">

                                @alergia.Gravedad
                            </span>
                        </div>

                        <p class="text-sm text-gray-500">@alergia.Tipo</p>
                        <p class="text-sm mt-2">@alergia.Descripcion</p>

                    </div>
                }

            </div>
        }

        <!-- ===================== -->
        <!-- ANTECEDENTES -->
        <!-- ===================== -->
        @if (activeTab == "antecedentes")
        {
            <div class="space-y-4">

                @foreach (var item in Paciente!.Antecedentes!)
                {
                    <div class="border-l-4 border-gray-300 pl-4">

                        <div class="flex justify-between">
                            <strong>@item.Tipo</strong>
                            <span class="text-xs text-gray-500">
                                @item?.Fecha?.ToString("dd/MM/yyyy")
                            </span>
                        </div>

                        <p>@item?.Descripcion</p>
                        <p class="text-sm text-gray-500">@item?.Observaciones</p>

                    </div>
                }

            </div>
        }

    </div>

</div>