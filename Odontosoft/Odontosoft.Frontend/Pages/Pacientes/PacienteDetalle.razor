@page "/pacientes/{Id:guid}"
@using Odontosoft.Frontend.Helpers
@using Odontosoft.Shared.Enums

<h3 class="mb-6 text-2xl font-semibold flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-clipboard-data"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M9 5h-2a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-12a2 2 0 0 0 -2 -2h-2" /><path d="M9 5a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2a2 2 0 0 1 -2 2h-2a2 2 0 0 1 -2 -2" /><path d="M9 17v-4" /><path d="M12 17v-1" /><path d="M15 17v-2" /><path d="M12 17v-1" /></svg>
    Historial del Paciente
</h3>

@if (Paciente == null)
{
    <div class="text-gray-500">Cargando...</div>
}
else
{

<div class="grid grid-cols-1 lg:grid-cols-12 lg:gap-6">

    <!-- FOTO Y ESTADO -->
    <div class="p-6 mb-6 bg-white shadow rounded-xl lg:mb-0 lg:col-span-12">

        <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">

            <!-- IZQUIERDA: FOTO + DATOS -->
            <div class="flex flex-col items-center w-full gap-4 sm:flex-row sm:items-center sm:gap-6">

                <!-- FOTO -->
                <div class="flex-shrink-0 w-24 h-24 overflow-hidden bg-gray-100 rounded-full md:w-32 md:h-32">
                    <img src="/user.jpg"
                        class="object-cover w-full h-full" />
                </div>

                <!-- DATOS -->
                <div class="flex flex-col items-center w-full text-center sm:items-start sm:text-left">

                    <span class="text-sm text-gray-500">
                        Expediente: @Paciente.NumeroExpediente
                    </span>

                    <h4 class="text-lg font-semibold md:text-xl">
                        @Paciente.Nombre @Paciente.Apellidos
                    </h4>

                    <p class="text-sm text-gray-500">
                        @Paciente.Direccion, @Paciente.Ciudad, @Paciente.Estado, @Paciente.CodigoPostal
                    </p>

                    <!-- INFO EXTRA -->
                    <div class="flex flex-col gap-2 mt-3 text-sm text-gray-500 sm:flex-row sm:gap-6">

                        <div class="flex items-center justify-center gap-2 sm:justify-start">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-phone"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /></svg>
                            Teléfono:
                            <span class="text-gray-900">@Paciente.Telefono</span>
                        </div>

                        <div class="flex items-center justify-center gap-2 sm:justify-start">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-calendar-time"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M11.795 21h-6.795a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v4" /><path d="M14 18a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" /><path d="M15 3v4" /><path d="M7 3v4" /><path d="M3 11h16" /><path d="M18 16.496v1.504l1 1" /></svg>
                            Última Visita:
                            <span class="text-gray-900">
                                @(
                                    Paciente.Citas?
                                        .Where(d => d.EstadoCita == EstadoCita.Completada.ToString())
                                        .OrderByDescending(d => d.FechaHora)
                                        .FirstOrDefault()?.FechaHora.ToString("dd/MM/yyyy")
                                    ?? "Sin registros"
                                )
                            </span>
                        </div>
                        

                    </div>

                </div>

            </div>

            <!-- DERECHA: ESTADO + BOTÓN -->
            <div class="flex flex-col items-center justify-center gap-3 sm:justify-center">

                <span class="px-3 py-1 text-xs rounded-full whitespace-nowrap
                    @(Paciente.Activo ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                    @(Paciente.Activo ? "Activo" : "Inactivo")
                </span>

                <button class="px-4 py-2 text-sm text-white bg-gray-500 rounded-xl hover:bg-gray-700 whitespace-nowrap">
                    Agendar Cita
                </button>

            </div>

        </div>

</div>


</div>
<div class="grid grid-cols-1 gap-6 mt-6 lg:grid-cols-12">

    <!-- CONTACTO -->
    <div class="p-6 bg-white shadow rounded-xl lg:col-span-5">

        <h4 class="flex items-center gap-2 mb-4 text-lg font-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-user-edit"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0" /><path d="M6 21v-2a4 4 0 0 1 4 -4h3.5" /><path d="M18.42 15.61a2.1 2.1 0 0 1 2.97 2.97l-3.39 3.42h-3v-3l3.42 -3.39" /></svg>
            Información</h4>

        <div class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">

            <div>
                <label class="block text-gray-500">Fecha de Nacimiento</label>
                <p class="text-gray-900 break-words">@Paciente.FechaNacimiento.ToString("dd MMM yyyy") (@DateHelper.GetAge(Paciente.FechaNacimiento) años)</p>
            </div>
            <div>
                <label class="block text-gray-500">Estado Civil</label>
                <p class="text-gray-900 break-words">@Paciente.EstadoCivil</p>
            </div>
            <div>
                <label class="block text-gray-500">Género</label>
                <p class="text-gray-900 break-words">@Paciente.Sexo</p>
            </div>

            <div>
                <label class="block text-gray-500">Grupo Sanguíneo</label>
                <p class="text-gray-900 break-words">@Paciente.GrupoSanguineo</p>
            </div>

            <div>
                <label class="block text-gray-500">Telefono</label>
                <p class="text-gray-900 break-words">@Paciente.Telefono</p>
            </div>
            <div>
                <label class="block text-gray-500">Contacto Emergencia</label>
                <p class="text-gray-900 break-words">@Paciente.ContactoEmergencia</p>
            </div>

        </div>

    </div>

    <!-- Signos Vitales  -->
<div class="p-6 bg-white shadow rounded-xl lg:col-span-7">

    <h4 class="flex items-center gap-2 mb-4 text-lg font-semibold">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-heartbeat"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M19.5 13.572l-7.5 7.428l-2.896 -2.868m-6.117 -8.104a5 5 0 0 1 9.013 -3.022a5 5 0 1 1 7.5 6.572" /><path d="M3 13h2l2 3l2 -6l1 3h3" /></svg>
    Signos Vitales (Última Consulta)</h4>

    @{
        var ultimaCita = Paciente?.Citas?
            .Where(d => d.EstadoCita == EstadoCita.Completada.ToString())
            .OrderByDescending(d => d.FechaHora)
            .FirstOrDefault();

        var ultimoSigno = ultimaCita?.Consulta;
    }

    @if (ultimoSigno != null)
    {
        <div class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-3">

            <div>
                <label class="block text-gray-500">Peso</label>
                <p class="text-gray-900">
                    @(ultimoSigno.Peso?.ToString() ?? "N/A") kg
                </p>
            </div>

            <div>
                <label class="block text-gray-500">Altura</label>
                <p class="text-gray-900">
                    @(ultimoSigno.Altura?.ToString() ?? "N/A") cm
                </p>
            </div>

            <div>
                <label class="block text-gray-500">Presión Arterial</label>
                <p class="text-gray-900">
                    @(ultimoSigno.PresionArterial ?? "N/A") mmHg    
                </p>
            </div>

            <div>
                <label class="block text-gray-500">Frecuencia Cardíaca</label>
                <p class="text-gray-900">
                    @(ultimoSigno.FrecuenciaCardiaca?.ToString() ?? "N/A") bpm  
                </p>
            </div>

            <div>
                <label class="block text-gray-500">Temperatura</label>
                <p class="text-gray-900">
                    @(ultimoSigno.Temperatura?.ToString() ?? "N/A") °C
                </p>
            </div>
            <div>
                <label class="block text-gray-500">IMC

                    @if(ultimoSigno.IMC < 18.5m)
                    {
                        <span class="px-2 py-1 ml-2 text-xs text-blue-700 bg-blue-100 rounded-full">
                            Bajo Peso
                        </span>
                    }
                    else if(ultimoSigno.IMC >= 18.5m && ultimoSigno.IMC < 25)
                    {
                        <span class="px-2 py-1 ml-2 text-xs text-green-700 bg-green-100 rounded-full">
                            Normal
                        </span>
                    }
                    else if(ultimoSigno.IMC >= 25 && ultimoSigno.IMC < 30)
                    {
                        <span class="px-2 py-1 ml-2 text-xs text-yellow-700 bg-yellow-100 rounded-full">
                            Sobrepeso
                        </span>
                    }
                    else if(ultimoSigno.IMC >= 30)
                    {
                        <span class="px-2 py-1 ml-2 text-xs text-red-700 bg-red-100 rounded-full">
                            Obesidad
                        </span>
                    }
                </label>
                <p class="text-gray-900">
                    @(ultimoSigno.IMC?.ToString() ?? "N/A") kg/m²
                </p>
            </div>
            <div>
                <label class="block text-gray-500">Frecuencia Respiratoria</label>
                <p class="text-gray-900">
                    @(ultimoSigno.FrecuenciaRespiratoria?.ToString() ?? "N/A")  rpm
                </p>
            </div>
            <div>
                <label class="block text-gray-500">Saturación de Oxígeno</label>
                <p class="text-gray-900">
                    @(ultimoSigno.SaturacionO2?.ToString() ?? "N/A") %
                </p>
            </div>

        </div>
    }
    else
    {
        <div class="text-sm text-center text-gray-500">
            No hay signos vitales registrados.
        </div>
    }

</div>

</div>

<!-- TABS -->

<div class="mt-6 bg-white shadow rounded-xl min-h-[500px]">

    <div class="flex text-sm border-b">

        <button @onclick="@(() => activeTab = "citas")" 
            
                class="px-4 py-3 @(activeTab == "citas" ? "border-b-2 border-gray-900 text-gray-900" : "text-gray-500")">
            Citas
        </button>

        <button @onclick="@(() => activeTab = "alergias")"
                class="px-4 py-3 @(activeTab == "alergias" ? "border-b-2 border-gray-900 text-gray-900" : "text-gray-500")">
            Alergias
        </button>
        <button 
                @onclick="@(() => activeTab = "antecedentes")"
                class="px-4 py-3 @(activeTab == "antecedentes" ? "border-b-2 border-gray-900 text-gray-900" : "text-gray-500")">
            Antecedentes
        </button>

    </div>

    <div class="p-6">

        <!-- ===================== -->
        <!-- CITAS -->
        <!-- ===================== -->
        @if (activeTab == "citas")
        {
            <div class="overflow-auto max-h-[300px]">

                <table class="min-w-full text-sm text-left">
                    <thead class="bg-gray-100">
                        <tr>
                            <th class="px-4 py-2">Número</th>
                            <th class="px-4 py-2">Fecha y Hora</th>
                            <th class="px-4 py-2">Motivo</th>
                            <th class="px-4 py-2">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Paciente?.Citas != null && Paciente.Citas.Any())
                        {
                            foreach (var cita in Paciente.Citas)
                            {
                                <tr class="border-b">
                                    <td class="px-4 py-2">@cita?.NumeroCita</td>

                                    <td class="px-4 py-2">
                                        @(cita?.FechaHora.ToString("dd MMM yyyy HH:mm tt") ?? "Sin fecha")
                                    </td>

                                    <td class="px-4 py-2">@cita?.MotivoConsulta</td>

                                    <td class="px-4 py-2">
                                        <span class="px-2 py-1 text-xs text-blue-700 bg-blue-100 rounded-full">
                                            @cita?.EstadoCita
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="px-4 py-2 text-center text-gray-500">
                                    No hay citas registradas.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        }

        <!-- ===================== -->
        <!-- ALERGIAS -->
        <!-- ===================== -->
        @if (activeTab == "alergias")
        {
            <div class="grid gap-4 md:grid-cols-2">

                @foreach (var alergia in Paciente!.Alergias!)
                {
                    <div class="p-4 border rounded-lg">

                        <div class="flex items-center justify-between mb-2">
                            <strong>@alergia.Nombre</strong>

                            <span class="text-xs px-2 py-1 rounded-full
                                @(alergia.Gravedad == "Alta" ? "bg-red-100 text-red-700" :
                                  alergia.Gravedad == "Media" ? "bg-yellow-100 text-yellow-700" :
                                  "bg-green-100 text-green-700")">

                                @alergia.Gravedad
                            </span>
                        </div>

                        <p class="text-sm text-gray-500">@alergia.Tipo</p>
                        <p class="mt-2 text-sm">@alergia.Descripcion</p>

                    </div>
                }

            </div>
        }

        <!-- ===================== -->
        <!-- ANTECEDENTES -->
        <!-- ===================== -->
        @if (activeTab == "antecedentes")
        {
            <div class="space-y-4">

                @foreach (var item in Paciente!.Antecedentes!)
                {
                    <div class="pl-4 border-l-4 border-gray-300">

                        <div class="flex justify-between">
                            <strong>@item.Tipo</strong>
                            <span class="text-xs text-gray-500">
                                @item?.Fecha?.ToString("dd/MM/yyyy")
                            </span>
                        </div>

                        <p>@item?.Descripcion</p>
                        <p class="text-sm text-gray-500">@item?.Observaciones</p>

                    </div>
                }

            </div>
        }

    </div>

</div>

}