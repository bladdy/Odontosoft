<!-- Mobile toggle -->
<button class="fixed z-50 p-2 text-white bg-gray-900 rounded-lg shadow md:hidden top-4 left-4"
        @onclick="ToggleNavMenu">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-menu-2"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M21 6a1 1 0 0 1 -1 1h-16a1 1 0 1 1 0 -2h16a1 1 0 0 1 1 1" /><path d="M21 12a1 1 0 0 1 -1 1h-16a1 1 0 0 1 0 -2h16a1 1 0 0 1 1 1" /><path d="M21 18a1 1 0 0 1 -1 1h-16a1 1 0 0 1 0 -2h16a1 1 0 0 1 1 1" /></svg>
</button>

<!-- Overlay mobile -->
@if (collapseNavMenu)
{
    <div class="fixed inset-0 z-40 bg-black/50 md:hidden" @onclick="ToggleNavMenu"></div>
}

<!-- Sidebar -->
<aside class="
    fixed md:static z-50
    h-full w-64
    bg-gray-900 text-white
    transform transition-transform duration-300
    @(collapseNavMenu ? "translate-x-0" : "-translate-x-full")
    md:translate-x-0
">

    <!-- Logo -->
    <div class="flex items-center justify-center h-16 text-xl font-bold border-b border-gray-700">
        Odontosoft
    </div>

    <!-- Menu -->
    <nav class="px-4 py-6 space-y-1">

        <!-- Home -->
        <NavLink href="/" Match="NavLinkMatch.All"
                 class="flex items-center gap-3 px-3 py-2 transition rounded hover:bg-gray-700"
                 activeClass="bg-gray-700"
                 >
            <!-- Icono SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round"
                 class="flex-shrink-0">
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M5 4h4a1 1 0 0 1 1 1v6a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1v-6a1 1 0 0 1 1 -1" />
                <path d="M5 16h4a1 1 0 0 1 1 1v2a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1v-2a1 1 0 0 1 1 -1" />
                <path d="M15 12h4a1 1 0 0 1 1 1v6a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1v-6a1 1 0 0 1 1 -1" />
                <path d="M15 4h4a1 1 0 0 1 1 1v2a1 1 0 0 1 -1 1h-4a1 1 0 0 1 -1 -1v-2a1 1 0 0 1 1 -1" />
            </svg>

            <!-- Texto -->
            <span class="flex-1">Dashboard</span>
        </NavLink>

        <!-- Paciente (Multinivel) -->
        <div class="block">
            <button @onclick="TogglePacienteMenu"
                    class="flex items-center justify-between w-full px-3 py-2 transition rounded hover:bg-gray-700">

                <!-- Grupo Icono + Texto -->
                <div class="flex items-center gap-3">
                    <!-- Icono Paciente -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                        <path d="M5 7a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" />
                        <path d="M3 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        <path d="M21 21v-2a4 4 0 0 0 -3 -3.85" />
                    </svg>

                    <!-- Texto -->
                    <span>Pacientes</span>
                </div>

                <!-- Flecha desplegable -->
                <span class="@((showPacienteSubMenu ? "rotate-180" : "rotate-0")) transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                        <path d="M6 10l6 6l6 -6h-12" />
                    </svg>
                </span>
            </button>



            <!-- Submenú Pacientes -->
            <div class="pl-4 mt-1 space-y-1 overflow-hidden transition-all duration-300 ease-in-out"
                 style="@($"max-height: {(showPacienteSubMenu ? "500px" : "0")}; opacity: {(showPacienteSubMenu ? "1" : "0")};")">


                <!-- Home -->
                <NavLink href="/pacientes/lista" Match="NavLinkMatch.All"
                         class="flex items-center gap-3 px-3 py-2 transition rounded hover:bg-gray-700"
                         activeClass="bg-gray-700"
                         >
                    <!-- Icono SVG -->
                    
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" 
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         class="flex-shrink-0">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M9 6l11 0" /><path d="M9 12l11 0" /><path d="M9 18l11 0" />
                    <path d="M5 6l0 .01" /><path d="M5 12l0 .01" /><path d="M5 18l0 .01" /></svg>

                    <!-- Texto -->
                    <span class="flex-1">Lista de Pacientes</span>
                </NavLink>
                <NavLink href="/pacientes/citas" Match="NavLinkMatch.All"
                         class="flex items-center gap-3 px-3 py-2 transition rounded hover:bg-gray-700"
                         activeClass="bg-gray-700"
                         >
                    <!-- Icono SVG -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" 
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         class="flex-shrink-0">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                        <path d="M10.5 21h-4.5a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v3" />
                        <path d="M16 3v4" />
                        <path d="M8 3v4" />
                        <path d="M4 11h10" />
                        <path d="M14 18a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" />
                        <path d="M18 16.5v1.5l.5 .5" />
                    </svg>
                    
                    <!-- Texto -->
                    <span class="flex-1">Citas de Pacientes</span>
                </NavLink>
                <NavLink href="/pacientes/consultas" Match="NavLinkMatch.All"
                         class="flex items-center gap-3 px-3 py-2 transition rounded hover:bg-gray-700"
                         activeClass="bg-gray-700"
                         >
                    <!-- Icono SVG -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-report-medical"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M9 5h-2a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-12a2 2 0 0 0 -2 -2h-2" /><path d="M9 5a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2a2 2 0 0 1 -2 2h-2a2 2 0 0 1 -2 -2" /><path d="M10 14l4 0" /><path d="M12 12l0 4" /></svg>
                    <!-- Texto -->
                    <span class="flex-1">Consultas de Pacientes</span>
                </NavLink>
            </div>
        </div>

    </nav>
</aside>

@code {
    private bool collapseNavMenu = true;
    private bool showPacienteSubMenu = false;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void TogglePacienteMenu()
    {
        showPacienteSubMenu = !showPacienteSubMenu;
    }

    private void ClosePacienteSubMenu()
    {
        // Si está abierto, ciérralo al hacer click en cualquier otra sección
        if (showPacienteSubMenu)
            showPacienteSubMenu = false;
    }
}
